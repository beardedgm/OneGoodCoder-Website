{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "8080", "-c-1"],
      "port": 8080
    },
    {
      "name": "live-reload",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=3000", "--no-browser"],
      "port": 3000
    },
    {
      "name": "python-server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
